---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../layouts/Layout.astro';
import { GalleryPage } from '../components/GalleryPage';
import "../styles/global.css";

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/**/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
);

const optimizedImages = await Promise.all(
  Object.entries(imageModules).map(async ([path, mod]) => {
    const [thumbnail, full] = await Promise.all([
      getImage({ src: mod.default, width: 800, format: 'webp', quality: 80 }),
      getImage({ src: mod.default, width: 1600, format: 'webp', quality: 85 }),
    ]);
    return { path, thumbnailSrc: thumbnail.src, fullSrc: full.src };
  }),
);
---

<Layout
  title="Monument Gallery | Ivey Monuments | Carroll County, IL"
  description="Browse granite monuments, flat markers, slants, benches, and custom memorial designs by Ivey Monuments, serving Carroll County and northwest Illinois since 1875."
>
  <GalleryPage client:load images={optimizedImages} />
</Layout>
