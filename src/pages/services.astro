---
import Layout from "../layouts/Layout.astro";
import { Navbar } from "../components/Navbar";
import { Footer } from "../components/Footer";
import {
  cemeteryCoverage,
  googleMapsUrl,
  localBusinessSchema,
  serviceAreas,
} from "../data/localSeo";

const title =
  "Monument Services in Northwest Illinois | Headstones & Cemetery Memorials";
const description =
  "Explore headstone and cemetery monument services from Ivey Monuments in Mt Carroll, IL. Serving Carroll, Whiteside, Jo Daviess, Ogle, and Lee counties.";

const servicePages = [
  {
    title: "Headstones & Memorials",
    description:
      "Custom granite headstones, flat markers, slants, and upright memorials with design, engraving, and installation.",
    href: "/services/headstones-memorials",
  },
  {
    title: "Cemeteries We Service",
    description:
      "Cemetery-specific planning for monument foundations, section rules, sizing limits, lettering, and long-term care.",
    href: "/services/cemetery-coverage",
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://iveymonuments.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Services",
      item: "https://iveymonuments.com/services",
    },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: servicePages.map((service, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: service.title,
    url: `https://iveymonuments.com${service.href}`,
  })),
};
---

<Layout title={title} description={description} structuredData={[localBusinessSchema, breadcrumbSchema, itemListSchema]}>
  <div class="min-h-screen bg-slate-50">
    <Navbar client:load />

    <section
      class="relative pt-32 pb-18 px-6 text-white"
      style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%);"
    >
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-amber-400 uppercase tracking-widest text-sm mb-4">Mt Carroll, Illinois</p>
        <h1 class="text-4xl md:text-5xl font-serif mb-6">Headstones and Cemetery Monument Services</h1>
        <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto">
          When your family needs a headstone or cemetery monument, you deserve clear guidance, dependable craftsmanship, and a team that understands local cemetery requirements. That is what we deliver.
        </p>
      </div>
    </section>

    <section class="py-16 px-6 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {servicePages.map((service) => (
            <article class="border border-slate-200 rounded-xl p-8 shadow-sm bg-white">
              <h2 class="text-2xl font-serif mb-3 text-slate-900">{service.title}</h2>
              <p class="text-slate-600 mb-6">{service.description}</p>
              <a
                href={service.href}
                class="inline-flex items-center px-5 py-3 rounded-lg text-white transition-opacity hover:opacity-90"
                style="background-color: var(--brand-primary);"
              >
                View Service Page
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-14 px-6 bg-slate-100">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-serif mb-6 text-slate-900">Service Area Coverage</h2>
        <p class="text-slate-700 mb-6 max-w-4xl">
          We work with families across northwest Illinois and coordinate directly with local cemeteries so each monument is approved, installed, and finished to cemetery standards.
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {serviceAreas.map((area) => (
            <li class="bg-white border border-slate-200 rounded-lg px-4 py-3 text-slate-700">{area}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="py-16 px-6 bg-white">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-serif mb-6 text-slate-900">Cemeteries We Regularly Serve</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {cemeteryCoverage.map((entry) => (
            <article class="rounded-xl border border-slate-200 p-6">
              <h3 class="text-xl font-semibold mb-3 text-slate-900">{entry.county}</h3>
              <ul class="space-y-2">
                {entry.cemeteries.map((cemetery) => (
                  <li class="text-slate-700 flex gap-2">
                    <span style="color: var(--brand-primary);">•</span>
                    {cemetery}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section
      class="py-16 px-6 text-center"
      style="background: linear-gradient(135deg, var(--brand-gradient-from), var(--brand-gradient-to));"
    >
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-serif mb-4 text-slate-900">Need Help Choosing the Right Memorial?</h2>
        <p class="text-slate-700 mb-8">
          Call <a href="tel:815-244-3034" class="underline">(815) 244-3034</a> for a no-pressure consultation or visit our
          <a href="/contact" class="underline"> contact page</a>.
        </p>
        <p class="text-slate-700 mb-6 text-sm">
          Prefer maps? <a href={googleMapsUrl} class="underline" target="_blank" rel="noopener noreferrer">Open Ivey Monuments on Google Maps</a>.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/services/headstones-memorials"
            class="px-6 py-3 rounded-lg text-white transition-opacity hover:opacity-90"
            style="background-color: var(--brand-primary);"
          >
            Browse Headstone Options
          </a>
          <a
            href="/services/cemetery-coverage"
            class="px-6 py-3 rounded-lg border border-slate-400 text-slate-800 hover:bg-slate-100 transition-colors"
          >
            View Cemetery Coverage
          </a>
        </div>
      </div>
    </section>

    <Footer client:load />
  </div>
</Layout>
